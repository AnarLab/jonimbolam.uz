# /env.example

# External entrypoint (only nginx is exposed)
NGINX_PORT=8080

# Postgres (internal only)
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app

# Django
DJANGO_SECRET_KEY=dev-insecure-secret
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Database URL used by Django (internal network host: db)
DATABASE_URL=postgres://app:app@db:5432/app

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Frontend API base URL (browser-side; should point to nginx)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Frontend internal API base URL (server-side Next.js inside docker network)
API_INTERNAL_BASE_URL=http://backend:8000